# Supabase transaction-pooler or direct Postgres connection string.
DATABASE_URL=

# Supabase Auth public configuration. The publishable key is intentionally
# browser-safe; never place a secret/service-role key in NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Generate with: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
RUN_SECRET_PEPPER_BASE64URL=

# Separately deployed pinned PolicyEngine service URL and shared server bearer.
TAX_SERVICE_URL=
TAX_SERVICE_TOKEN=
# Explicit fallback for hosts that cannot start the PolicyEngine Python bundle.
# This uses the simplified educational tax calculator, not PolicyEngine.
# TAX_CALCULATOR_MODE=deterministic

# Optional server-only provider for onboarding/future asynchronous narration.
# Monthly gameplay uses bundled operational ML and ignores these settings.
# Never expose provider keys to a browser.
AI_PROVIDER=groq
GROQ_API_KEY=

# Legacy provider-ranking settings retained for isolated adapter tests. The
# normal RunService monthly path does not call a provider or model server.
AI_GAMEPLAY_MODE=off
AI_GAMEPLAY_TIMEOUT_MS=8000
AI_GAMEPLAY_SAMPLE_EVERY_MONTHS=3
AI_GAMEPLAY_MINIMUM_CANDIDATES=2

# Optional OpenAI runtime path when the project has GPT-5.6 API entitlement.
OPENAI_API_KEY=

# Local development only: set AI_PROVIDER=ollama to use gpt-oss:20b without an
# OpenAI API key. The runtime rejects non-loopback origins.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Versioned AES-256-GCM audit keyring as compact JSON with canonical base64 keys.
# Generate a key with: openssl rand -base64 32
# Example shape only: {"1":"<44-character canonical base64 key>"}
AI_AUDIT_ENCRYPTION_KEYS=
AI_AUDIT_ACTIVE_KEY_VERSION=1

# Separate 256-bit administrator bearer used only for encrypted audit reads.
# Generate the suffix with: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
# Required shape: lf_audit_<43-character base64url suffix>
AI_AUDIT_ADMIN_TOKEN=
