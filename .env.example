# Supabase transaction-pooler or direct Postgres connection string.
DATABASE_URL=

# Generate with: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
RUN_SECRET_PEPPER_BASE64URL=

# Separately deployed pinned PolicyEngine service URL and shared server bearer.
TAX_SERVICE_URL=
TAX_SERVICE_TOKEN=

# Server-only OpenAI project key with GPT-5.6 access. Never expose it to a browser.
AI_PROVIDER=openai
OPENAI_API_KEY=

# Local development only: set AI_PROVIDER=ollama to use gpt-oss:20b without an
# OpenAI API key. The runtime rejects non-loopback origins.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Versioned AES-256-GCM audit keyring as compact JSON with canonical base64 keys.
# Generate a key with: openssl rand -base64 32
# Example shape only: {"1":"<44-character canonical base64 key>"}
AI_AUDIT_ENCRYPTION_KEYS=
AI_AUDIT_ACTIVE_KEY_VERSION=1

# Separate 256-bit administrator bearer used only for encrypted audit reads.
# Generate the suffix with: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
# Required shape: lf_audit_<43-character base64url suffix>
AI_AUDIT_ADMIN_TOKEN=
