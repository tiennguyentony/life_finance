{
  "name": "life-finance",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "drizzle-kit migrate",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check:test-layout": "node scripts/check-test-layout.mjs",
    "test:parallel": "vitest run --exclude src/core/__tests__/financial-projection-v2.test.ts --exclude src/core/__tests__/time-controller-v2.test.ts --exclude src/lab/__tests__/balance-lab-v1.performance.test.ts",
    "test:long-run": "vitest run src/core/__tests__/financial-projection-v2.test.ts src/core/__tests__/time-controller-v2.test.ts src/lab/__tests__/balance-lab-v1.performance.test.ts --no-file-parallelism",
    "balance:quick": "node scripts/run-balance-lab.mjs --size quick",
    "balance:medium": "node scripts/run-balance-lab.mjs --size medium",
    "balance:large": "node scripts/run-balance-lab.mjs --size large",
    "test": "pnpm check:test-layout && pnpm test:parallel && pnpm test:long-run",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "9.0.0",
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "openai": "6.47.0",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
