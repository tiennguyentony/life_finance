{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "web": {
      "root": ".",
      "framework": "nextjs",
      "buildCommand": "node scripts/vercel-build.mjs",
      "bindings": [
        {
          "type": "service",
          "service": "tax_service",
          "format": "url",
          "env": "TAX_SERVICE_URL"
        }
      ]
    },
    "tax_service": {
      "root": "services/tax",
      "entrypoint": "api/index.py",
      "framework": "fastapi",
      "functions": {
        "api/index.py": {
          "maxDuration": 300
        }
      }
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "service": "web"
      }
    }
  ]
}
