{
    "services": {
        "frontend": {
            "root": ".",
            "framework": "nextjs"
        },
        "tax": {
            "root": "services/tax"
        }
    },
    "rewrites": [
        {
            "source": "/api/tax(/.*)?",
            "destination": {
                "type": "service",
                "service": "tax"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}
