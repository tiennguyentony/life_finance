{
  "services": {
    "frontend": {
      "root": ".",
      "framework": "nextjs",
      "buildCommand": "node scripts/vercel-build.mjs"
    },
    "tax": {
      "root": "services/tax",
      "entrypoint": "api/index.py"
    }
  },
  "rewrites": [
    {
      "source": "/api/tax(/.*)?",
      "destination": {
        "type": "service",
        "service": "tax"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ]
}
